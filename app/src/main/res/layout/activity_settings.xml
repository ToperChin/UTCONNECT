<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#008080" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Configuración y Privacidad"
            android:textColor="#008080"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Sección Cuenta -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuenta"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#F1F5F9">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDatosPersonales"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Datos Personales"
                        android:textAlignment="viewStart"
                        android:textColor="#333333"
                        app:icon="@android:drawable/ic_menu_myplaces"
                        app:iconTint="#008080" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSeguridad"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Seguridad"
                        android:textAlignment="viewStart"
                        android:textColor="#333333"
                        app:icon="@android:drawable/ic_lock_idle_lock"
                        app:iconTint="#008080" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNotificaciones"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Notificaciones"
                        android:textAlignment="viewStart"
                        android:textColor="#333333"
                        app:icon="@android:drawable/ic_popup_reminder"
                        app:iconTint="#008080" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrivacidad"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Privacidad"
                        android:textAlignment="viewStart"
                        android:textColor="#333333"
                        app:icon="@android:drawable/ic_lock_lock"
                        app:iconTint="#008080" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sección Soporte -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Soporte"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#F1F5F9">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAyudaSoporte"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Ayuda y Soporte"
                        android:textAlignment="viewStart"
                        android:textColor="#333333"
                        app:icon="@android:drawable/ic_menu_help"
                        app:iconTint="#008080" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTerminosPoliticas"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Terminos y Politicas"
                        android:textAlignment="viewStart"
                        android:textColor="#333333"
                        app:icon="@android:drawable/ic_menu_info_details"
                        app:iconTint="#008080" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sección Acciones -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acciones"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#F1F5F9">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReportarProblema"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Reportar Problema"
                        android:textAlignment="viewStart"
                        android:textColor="#333333"
                        app:icon="@android:drawable/ic_menu_report_image"
                        app:iconTint="#008080" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAnadirCuenta"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Añadir cuenta"
                        android:textAlignment="viewStart"
                        android:textColor="#333333"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconTint="#008080" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCerrarSesion"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Cerrar Sesion"
                        android:textAlignment="viewStart"
                        android:textColor="#333333"
                        app:icon="@android:drawable/ic_lock_power_off"
                        app:iconTint="#008080" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
